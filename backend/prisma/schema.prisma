generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TemplateStatus {
  ACTIVE
  DISABLED
  DRAFT
  EXPIRED
}

enum PricingMethod {
  PRICE_BY_DESTINATION
  PRICE_BY_HOURS
  PRICE_BY_ROUTE
  PRICE_BY_DISTANCE
  PRICE_BY_AREA
  PRICE_BY_PASSENGERS
  PRICE_BY_SKU
  PRICE_BY_MINUTES
  PRICE_BY_KM_AND_HOURS
}

enum FieldType {
  TEXT
  NUMBER
  DROPDOWN
  BOOLEAN
  DATE
  TIME
}

enum CatalogStatus {
  ACTIVE
  DISABLED
  DRAFT
}

enum LogCategory {
  INCOMING_REQUEST
  OUTGOING_RESPONSE
  PRICING_RESULT
  EXTERNAL_CALLBACK
  ERROR
}

enum UserRole {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  name          String
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  loginAttempts Int        @default(0) @map("login_attempts")
  lockedUntil   DateTime?  @map("locked_until")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  templates     Template[]
  catalogs      Catalog[]

  @@map("users")
}

model Template {
  id                   String         @id @default(uuid())
  name                 String
  description          String         @default("")
  supplementsAdditions String         @default("") @map("supplements_additions")
  status               TemplateStatus @default(DRAFT)
  pricingMethod        PricingMethod  @map("pricing_method")
  createdById   String         @map("created_by_id")
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  fields        TemplateField[]
  catalogs      Catalog[]

  @@map("templates")
}

model TemplateField {
  id         String    @id @default(uuid())
  templateId String    @map("template_id")
  template   Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldKey   String    @map("field_key")
  labelEn    String    @map("label_en")
  labelHe    String    @map("label_he")
  fieldType  FieldType @map("field_type")
  options    Json?
  required   Boolean   @default(true)
  sortOrder  Int       @default(0) @map("sort_order")

  @@unique([templateId, fieldKey])
  @@map("template_fields")
}

model Catalog {
  id              String        @id @default(uuid())
  name            String
  description     String        @default("")
  status          CatalogStatus @default(DRAFT)
  templateId      String        @map("template_id")
  template        Template      @relation(fields: [templateId], references: [id])
  fieldValues     Json          @map("field_values")
  calculatedPrice Decimal?      @map("calculated_price") @db.Decimal(12, 2)
  createdById     String        @map("created_by_id")
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("catalogs")
}

model SystemLog {
  id              String       @id @default(uuid())
  category        LogCategory
  method          String?
  path            String?
  statusCode      Int?         @map("status_code")
  source          String?
  externalId      String?      @map("external_id")
  pricingMethod   String?      @map("pricing_method")
  requestBody     Json?        @map("request_body")
  responseBody    Json?        @map("response_body")
  calculatedPrice Decimal?     @map("calculated_price") @db.Decimal(12, 2)
  durationMs      Int?         @map("duration_ms")
  errorMessage    String?      @map("error_message")
  isDummy         Boolean      @default(false) @map("is_dummy")
  userId          String?      @map("user_id")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([category, createdAt])
  @@map("system_logs")
}

model AppSettings {
  id                         String   @id @default("default")
  appName                    String   @default("Maya Pricing") @map("app_name")
  jwtExpiresIn               String   @default("7d") @map("jwt_expires_in")
  loginAttemptLimit          Int      @default(5) @map("login_attempt_limit")
  lockoutDurationMinutes     Int      @default(15) @map("lockout_duration_minutes")
  allowOnlyActiveTemplates   Boolean  @default(true) @map("allow_only_active_templates")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
