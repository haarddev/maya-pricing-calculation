generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TemplateStatus {
  ACTIVE
  DISABLED
  DRAFT
  EXPIRED
}

enum PricingMethod {
  PRICE_BY_DESTINATION
  PRICE_BY_HOURS
  PRICE_BY_ROUTE
  PRICE_BY_DISTANCE
  PRICE_BY_AREA
}

enum FieldType {
  TEXT
  NUMBER
  DROPDOWN
  BOOLEAN
  DATE
  TIME
}

enum CatalogStatus {
  ACTIVE
  DISABLED
  DRAFT
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  templates    Template[]
  catalogs     Catalog[]

  @@map("users")
}

model Template {
  id            String         @id @default(uuid())
  name          String
  description   String         @default("")
  status        TemplateStatus @default(DRAFT)
  pricingMethod PricingMethod  @map("pricing_method")
  createdById   String         @map("created_by_id")
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  fields        TemplateField[]
  catalogs      Catalog[]

  @@map("templates")
}

model TemplateField {
  id         String    @id @default(uuid())
  templateId String    @map("template_id")
  template   Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldKey   String    @map("field_key")
  labelEn    String    @map("label_en")
  labelHe    String    @map("label_he")
  fieldType  FieldType @map("field_type")
  options    Json?
  required   Boolean   @default(true)
  sortOrder  Int       @default(0) @map("sort_order")

  @@unique([templateId, fieldKey])
  @@map("template_fields")
}

model Catalog {
  id              String        @id @default(uuid())
  name            String
  description     String        @default("")
  status          CatalogStatus @default(DRAFT)
  templateId      String        @map("template_id")
  template        Template      @relation(fields: [templateId], references: [id])
  fieldValues     Json          @map("field_values")
  calculatedPrice Decimal?      @map("calculated_price") @db.Decimal(12, 2)
  createdById     String        @map("created_by_id")
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("catalogs")
}
