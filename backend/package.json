{
  "name": "maya-pricing-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prebuild": "node scripts/prisma-generate-safe.mjs",
    "start": "node dist/index.js",
    "seed": "node scripts/load-env.mjs tsx prisma/seed.ts",
    "prisma:generate": "node scripts/prisma-generate-safe.mjs",
    "prisma:push": "node scripts/load-env.mjs npx prisma db push",
    "prisma:migrate": "node scripts/load-env.mjs npx prisma migrate deploy",
    "prisma:studio": "node scripts/load-env.mjs npx prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.3",
    "prisma": "^6.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
