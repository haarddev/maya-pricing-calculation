DATABASE_USERNAME=postgres
DATABASE_PASSWORD=YOUR_PASSWORD
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=maya_pricing
# Optional: Prisma CLI reads this directly. If omitted, npm scripts build it from the vars above.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/maya_pricing
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PORT=4000
CORS_ORIGIN=http://localhost:5173
ITURAN_BASE_URL=https://api.ituran.com/api/v1
ITURAN_USERNAME=
ITURAN_PASSWORD=
# Optional override for validate:ituran (defaults to prisma/data/ituran-mod-sample.xlsx)
# ITURAN_EXCEL_PATH=
